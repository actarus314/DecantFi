{
  "name": "decantfi",
  "version": "0.1.0",
  "private": true,
  "description": "Recommandeur de route nette BLND -> USDC/EURC sur Stellar (meta-agregateur de cotations, read-only). DecantFi.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "quote": "tsx cli/index.ts",
    "history": "tsx cli/history.ts",
    "export": "tsx cli/history.ts export",
    "tick:once": "tsx collector/tick-once.ts",
    "collector": "tsx collector/daemon.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "web": "tsx web/server.ts",
    "build:walletkit": "npx --yes esbuild web/walletkit.entry.js --bundle --format=esm --platform=browser --define:global=globalThis --target=es2020 --outfile=web/public/walletkit.js"
  },
  "devDependencies": {
    "@creit.tech/stellar-wallets-kit": "^2.3.0",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@soroswap/sdk": "^0.4.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "soroswap-router-sdk": "^1.4.6"
  }
}
