# ─── Template .env — copier vers .env et remplir. Ne JAMAIS committer .env. ───

# ─── DecantFi — config & clés ───
# Clé API Soroswap (cotations READ-ONLY, token sk_…). Inscription gratuite : https://api.soroswap.finance
# OPTIONNEL : sans clé, l'outil tourne sur les sources keyless (xBull/Aquarius/StellarBroker/UltraStellar/Horizon/Comet).
SOROSWAP_API_KEY=
# STELLARBROKER_API_KEY=        # reserved: key-based StellarBroker integration (source currently disconnected; keyless endpoint is Cloudflare-rate-limited)

# Endpoints réseau (publics, pas des secrets — surchargeables)
STELLAR_RPC_URL=https://mainnet.sorobanrpc.com
# STELLAR_RPC_URL_FALLBACK=https://mainnet.sorobanrpc.com
STELLAR_HORIZON_URL=https://horizon.stellar.org
# Optional: default Stellar address (G…) for the CLI `decant --balance` command.
# CLI-only — ignored by the Docker/web deployment.
# WALLET_ADDRESS=

# ─── collecteur (Phase 2) ───
COLLECTOR_CADENCE_SEC=900            # défaut 15 min
COLLECTOR_JITTER_SEC=60
COLLECTOR_SIZES_BLND=250,750
COLLECTOR_PAIRS=USDC,EURC
COLLECTOR_DB_PATH=./data/quotes.db   # prod : /app/data/quotes.db
COLLECTOR_TIMEOUT_MS=15000
RAW_RETENTION_DAYS=90
ROLLUP_AFTER_DAYS=365                # 0 = off ; ici actif

# ─── UI web (Phase 2 – sous-projet 2) ───
# The web container ALWAYS listens on 8080 internally — do NOT change this to remap
# the published port (it would desync the compose port mapping and the healthcheck,
# making the container unreachable and unhealthy). To change the published host port,
# use WEB_HOST_PORT in the Docker section below.
# WEB_PORT=8080

# ─── Docker / déploiement ───
# Chemin hôte des données / host data path (défaut: ./data ; ex. NUC: /docker/decantfi/backend/data)
DECANTFI_DATA=./data
# Owner GHCR de l'image (défaut: actarus314 ; mets ton compte si tu forkes)
IMAGE_OWNER=actarus314
# Tag de l'image à déployer (épingler en prod, ex: 1.2.3 — jamais latest en production)
# IMAGE_TAG=latest
# Host port to publish the web UI on (the container side is always 8080).
# WEB_HOST_PORT=8080
