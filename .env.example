# ─────────────────────────────────────────────────────────────────────────────
# DecantFi — environment template. Copy to .env and adjust. NEVER commit .env.
#
# Uncommented lines carry the built-in DEFAULT value: copying this file as-is
# reproduces the default behaviour. Commented (#) lines are optional and have no
# default unless stated. A shown value that is an illustration rather than a real
# default is marked "(example)".
# ─────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════ APPLICATION ════════════════════════════════════
# Read by the app itself (collector daemon, web server, CLI) at runtime.

# --- API keys (optional) ---
# Soroswap API key (sk_… token). Used only by the EXECUTION path to build
# Soroswap transactions — quoting stays keyless. Free signup: https://api.soroswap.finance
SOROSWAP_API_KEY=
# StellarBroker API key. Reserved for the key-based integration (the source is
# currently disconnected; its keyless endpoint is Cloudflare-rate-limited).
# STELLARBROKER_API_KEY=

# --- Network endpoints (public, not secrets) ---
STELLAR_RPC_URL=https://mainnet.sorobanrpc.com
STELLAR_HORIZON_URL=https://horizon.stellar.org
# Optional fallback RPC, switched in per-tick if the primary fails. No default
# (a single endpoint is used when unset). Use a DISTINCT endpoint to be useful.
# STELLAR_RPC_URL_FALLBACK=https://your-backup-rpc.example.com   # (example)

# --- Collector ---
COLLECTOR_CADENCE_SEC=900        # tick period in seconds (900 = 15 min)
COLLECTOR_JITTER_SEC=60          # random ± jitter added to the cadence
COLLECTOR_SIZES_BLND=250,750     # probe sizes in BLND; the web UI probe toggles follow this
COLLECTOR_PAIRS=USDC,EURC        # target assets to quote BLND against
COLLECTOR_TIMEOUT_MS=15000       # per-source quote timeout
RAW_RETENTION_DAYS=90            # keep per-quote raw rows this many days
ROLLUP_AFTER_DAYS=365            # roll up then drop per-tick rows after N days (0 = off)
# SQLite DB path — only matters for LOCAL/CLI runs (default ./data/quotes.db).
# Under Docker it is force-set to /app/data/quotes.db by docker-compose.yaml
# (its `environment:` overrides .env), so a value here is ignored. Leave commented.
# COLLECTOR_DB_PATH=./data/quotes.db

# --- CLI only ---
# Default Stellar address (G…) for `decant --balance`. Ignored by the Docker/web
# deployment. No default.
# WALLET_ADDRESS=


# ═══════════════════════════ DEPLOYMENT (Docker) ════════════════════════════
# Consumed by docker-compose, not by the application code.
# These have NO fallback in the compose file — keep them set, otherwise
# `docker compose up` resolves them to empty and fails.

# Host directory mounted as the data volume. Default ./data; on a server e.g.
# /docker/decantfi/backend/data
DECANTFI_DATA=./data
# Host port to publish the web UI on. Default 8088, deliberately different from the
# container's internal 8080 so the host:container mapping (8088:8080) is obvious.
WEB_HOST_PORT=8088
# Image tag to deploy. Default "latest"; PIN a specific release in production.
IMAGE_TAG=latest
