# ─── Template .env — copier vers .env et remplir. Ne JAMAIS committer .env. ───

# GitHub — PAT fine-grained RESTREINT À CE SEUL REPO
#   Permissions: Contents R/W · Metadata R · Pull requests R/W · Issues R/W · Workflows R/W · Actions R
#   Exposé à git/gh par direnv (.envrc → export GH_TOKEN=$GITHUB_PAT). Voir workspace/secrets.md.
GITHUB_PAT=

# ─── stellar-swap — config & clés ───
# Clé API Soroswap (cotations READ-ONLY, token sk_…). Inscription gratuite : https://api.soroswap.finance
# OPTIONNEL : sans clé, l'outil tourne sur les sources keyless (xBull/Aquarius/StellarBroker/UltraStellar/Horizon/Comet).
SOROSWAP_API_KEY=

# Endpoints réseau (publics, pas des secrets — surchargeables)
STELLAR_RPC_URL=https://mainnet.sorobanrpc.com
STELLAR_HORIZON_URL=https://horizon.stellar.org

# ─── collecteur (Phase 2) ───
COLLECTOR_CADENCE_SEC=900            # défaut 15 min
COLLECTOR_JITTER_SEC=60
COLLECTOR_SIZES_BLND=250,750
COLLECTOR_PAIRS=USDC,EURC
COLLECTOR_DB_PATH=./data/quotes.db   # prod : /app/data/quotes.db
COLLECTOR_TIMEOUT_MS=15000
RAW_RETENTION_DAYS=90
ROLLUP_AFTER_DAYS=365                # 0 = off ; ici actif

# ─── UI web (Phase 2 – sous-projet 2) ───
WEB_PORT=8080
